# ====== ModelRadar 环境变量模板 ======
# 把这个文件复制成 .env 后填入真实值：cp .env.example .env

# ------ GitHub ------
# 从 https://github.com/settings/tokens 生成，只需 public_repo 只读权限
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ------ 邮件 (163 SMTP) ------
# 发件邮箱和授权码 (不是登录密码！163 邮箱设置 → POP3/SMTP → 开启并生成授权码)
EMAIL_SENDER=your_email@163.com
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx
# 收件人列表，多人用逗号分隔
EMAIL_RECEIVERS=receiver@qq.com

# ------ LLM (Phase 3 才需要) ------
# DeepSeek API key，用于 Reddit 社区总结 + 周报生成
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ------ HuggingFace (Phase 4，可选) ------
# 不填也能工作，填了可提高速率限制
HF_TOKEN=

# ------ 存储 ------
# SQLite 数据库路径，Railway 会挂 Volume 到 /app/data
DB_PATH=./data/model_radar.db

# ------ 运行参数 ------
# 采集频率 (分钟)，可按 Railway 资源调整
INTERVAL_LEADERBOARD_MIN=1440
INTERVAL_GITHUB_MIN=60
INTERVAL_DIFF_MIN=60
INTERVAL_P0_ALERT_MIN=30
INTERVAL_REDDIT_MIN=360
# HuggingFace trending/downloads 榜 4h 一次
INTERVAL_HF_MIN=240
# 厂商官方博客（OpenAI / Anthropic / Google / Meta）1h 一次，求快
INTERVAL_BLOG_MIN=60
# OpenRouter 周榜 7d 一次（OR 自己就是周粒度聚合，高频没意义）
INTERVAL_OPENROUTER_MIN=10080
# 微信公众号 1 天 1 次（WeWe-RSS 后端自己已限速）
INTERVAL_WECHAT_MIN=1440
# Dashboard 聚合缓存（社区声音/本周热议）12h 一次，供前端秒开读缓存
INTERVAL_MINI_DIGEST_MIN=720

# ------ Reddit (Phase 3) ------
# Railway 美国机可直连，留空即可；本地调试想走代理：REDDIT_PROXY=http://127.0.0.1:7890
REDDIT_PROXY=
# 要跟踪的 subreddit，逗号分隔。留空用默认 LocalLLaMA,StableDiffusion,singularity,ChatGPT
REDDIT_SUBS=

# 启动时是否立即冷启动跑一轮采集
COLD_START_ON_BOOT=true

# ------ Dashboard (Phase 2) ------
# 前端访问地址 http://<host>:<PORT>/
# Basic Auth 用户名/密码。PASS 为空时禁用 Basic Auth (仅本地调试)
DASHBOARD_USER=radar
DASHBOARD_PASS=change_me_to_a_long_random_string
PORT=8000
INTERVAL_HEAT_MIN=180
